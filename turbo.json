{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"install": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^install", "^build"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"persistent": true,
			"cache": false
		}
	}
}
